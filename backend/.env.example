APP_NAME=AgentHQ
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://agenthq:agenthq@localhost:5432/agenthq
BACKEND_CORS_ORIGINS=http://localhost:5173
JWT_SECRET_KEY=replace-with-a-long-random-secret
BOOTSTRAP_SECRET=replace-with-a-separate-long-random-secret
ALLOW_PUBLIC_REGISTRATION=true
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMITS_ENABLED=true
REDIS_URL=
SENSITIVE_RATE_LIMIT_WINDOW_SECONDS=60
INVITE_CREATE_RATE_LIMIT_ATTEMPTS=10
APPROVAL_RATE_LIMIT_ATTEMPTS=30
EXECUTION_RATE_LIMIT_ATTEMPTS=60
MCP_SYNC_RATE_LIMIT_ATTEMPTS=5
POLICY_DECISION_RATE_LIMIT_ATTEMPTS=60
COMPLIANCE_RATE_LIMIT_ATTEMPTS=30
ALLOW_PRIVATE_MCP_URLS=true
MCP_DISCOVERY_MODE=mock
GATEWAY_LIST_RATE_LIMIT_ATTEMPTS=60
GATEWAY_CALL_RATE_LIMIT_ATTEMPTS=30
GATEWAY_TOKEN_RATE_LIMIT_ATTEMPTS=10
# Real-mode credentials are referenced by MCP server auth_secret_ref, for example:
# MCP_AUTH_CUSTOMER_OPERATIONS=replace-with-secret
